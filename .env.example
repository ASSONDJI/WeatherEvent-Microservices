# Variables d'environnement pour le projet WeatherEvent Microservices
# Copier ce fichier vers .env.local et ajouter tes vraies clés

# OpenWeatherMap API Key (obtenir sur https://openweathermap.org/api)
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Ticketmaster API Key (obtenir sur https://developer.ticketmaster.com/)
TICKETMASTER_API_KEY=your_ticketmaster_api_key_here

# Pour Docker Compose, décommenter et ajouter les clés
# OPENWEATHER_API_KEY=ta_clé_ici
# TICKETMASTER_API_KEY=ta_clé_ici
